# PostgreSQL. For production add connection pool: ?connection_limit=20 (or higher under load).
DATABASE_URL="postgresql://user:password@localhost:5432/myshopuz"
JWT_SECRET=your-super-secret-key-min-32-chars

# Rate limit: requests per window. With REDIS_URL, limits are shared across API replicas.
# THROTTLE_LIMIT_SHORT=300
# THROTTLE_LIMIT_LONG=2000

# Admin without seed: at startup create/update user with role ADMIN (optional)
ADMIN_EMAIL=
ADMIN_PASSWORD=
# ADMIN_FIRST_NAME=Admin
# ADMIN_LAST_NAME=MyShop
JWT_ACCESS_EXPIRES=15m
CORS_ORIGIN=http://localhost:3000
REDIS_URL=redis://localhost:6379
# Cloudinary (optional). If not set, images are stored locally in uploads/ and served at /uploads/
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Public base URL for local uploads (e.g. https://yourdomain.com/api-proxy). Default: APP_URL + /api-proxy
# API_PUBLIC_URL=
SENTRY_DSN=
CSRF_SECRET=your-csrf-secret-min-32-characters-for-production
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=
PAYME_MERCHANT_ID=
PAYME_KEY=
# Telegram bot (create via @BotFather). Optional: site URL for "Ko'rish" links in notifications
TELEGRAM_BOT_TOKEN=
# Bot username without @ (e.g. MyShopUZBot) — for "Login via Telegram" link on site
TELEGRAM_BOT_USERNAME=
# Admin Telegram Chat ID (optional). Agar sozlamalarda yoki kod orqali ulanmagan bo'lsa, shu ishlatiladi
ADMIN_TELEGRAM_CHAT_ID=
APP_URL=http://localhost:3000
# Optional: SMTP for OTP emails (if not set, OTP is logged to console in dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@myshop.uz
