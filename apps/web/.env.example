NEXT_PUBLIC_API_URL=http://localhost:4000

# --- Production (set these before "pnpm build" / at build time) ---
# Same build ID on all instances avoids "Failed to find Server Action" and "Cannot read properties of undefined (reading 'workers')".
# BUILD_ID=your_release_id
# In CI (GitHub/GitLab/Vercel) BUILD_ID can be omitted: we use GITHUB_SHA / CI_COMMIT_SHA / VERCEL_GIT_COMMIT_SHA when available.

# Required in production: set at BUILD TIME (same value on every build server). Base64, 32 bytes.
# Generate once and store in secrets: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=your_base64_key_here
