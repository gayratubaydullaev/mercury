NEXT_PUBLIC_API_URL=http://localhost:4000

# Production: set BUILD_ID in CI (e.g. $CI_COMMIT_SHA or fixed per release) so all instances use same build.
# BUILD_ID=abc123

# Production: set to a fixed base64 key (32 bytes) to avoid "Failed to find Server Action" / workers undefined.
# Generate once: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=your_base64_key_here
